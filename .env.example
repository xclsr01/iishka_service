APP_ENV=development
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8787
VITE_API_BASE_URL=http://localhost:8787
VITE_ENABLE_DEV_AUTH=true
VITE_DEV_AUTH_SHARED_SECRET=replace_with_dev_auth_secret
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iishka_service?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/iishka_service?schema=public"

JWT_SECRET=replace_with_a_long_random_secret
SESSION_TTL_MINUTES=10080
TELEGRAM_INIT_DATA_TTL_SECONDS=3600

TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_BOT_USERNAME=replace_with_bot_username
TELEGRAM_WEBHOOK_SECRET=replace_with_webhook_secret
TELEGRAM_MINI_APP_URL=https://your-mini-app-domain.example.com
TELEGRAM_DELIVERY_MODE=polling

OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_ENABLED=true
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GOOGLE_AI_API_KEY=replace_with_google_ai_api_key
GOOGLE_AI_MODEL=gemini-2.0-flash

MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain
UPLOAD_STORAGE_DRIVER=local
UPLOAD_LOCAL_DIR=./storage/uploads
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=chat-uploads

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

ENABLE_DEV_AUTH=true
DEV_AUTH_SHARED_SECRET=replace_with_dev_auth_secret
ENABLE_DEV_SUBSCRIPTION_OVERRIDE=true
