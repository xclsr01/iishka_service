{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "iishka-backend",
  "main": "src/worker.ts",
  "keep_vars": true,
  "vars": {
    "API_BASE_URL": "https://iishka-backend.artemveselov991.workers.dev",
    "ANTHROPIC_MODEL": "claude-3-5-sonnet-latest",
    "APP_ENV": "production",
    "ENABLE_DEV_AUTH": "false",
    "ENABLE_DEV_SUBSCRIPTION_OVERRIDE": "false",
    "FRONTEND_URL": "https://iishka-service.pages.dev",
    "GOOGLE_AI_MODEL": "gemini-2.0-flash",
    "OPENAI_MODEL": "gpt-4.1-mini",
    "SUPABASE_STORAGE_BUCKET": "chat-uploads",
    "SUPABASE_URL": "https://pehujciaiihjuzduysln.supabase.co",
    "TELEGRAM_BOT_USERNAME": "iishkaApp",
    "TELEGRAM_MINI_APP_URL": "https://iishka-service.pages.dev",
    "TELEGRAM_DELIVERY_MODE": "webhook"
  },
  "compatibility_date": "2026-03-17",
  "compatibility_flags": [
    "nodejs_compat",
    "nodejs_compat_populate_process_env"
  ],
  "observability": {
    "enabled": true
  }
}
