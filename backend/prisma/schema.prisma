generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderKey {
  OPENAI
  ANTHROPIC
  GEMINI
  NANO_BANANA
  VEO
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageStatus {
  COMPLETED
  FAILED
  STREAMING
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PAST_DUE
  TRIALING
  INACTIVE
}

enum FileStatus {
  READY
  REJECTED
  QUARANTINED
}

enum GenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum GenerationJobKind {
  IMAGE
  MUSIC
  VIDEO
  PROVIDER_ASYNC
}

enum ProviderUsageOperation {
  CHAT_GENERATION
  JOB_GENERATION
}

enum IdempotencyRequestStatus {
  IN_PROGRESS
  COMPLETED
}

enum IdempotencyAction {
  MESSAGE_CREATE
  GENERATION_JOB_CREATE
}

model User {
  id               String         @id @default(cuid())
  telegramUserId   String         @unique
  telegramUsername String?
  firstName        String?
  lastName         String?
  languageCode     String?
  avatarUrl        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  chats            Chat[]
  messages         Message[]
  subscriptions    Subscription[]
  files            FileAsset[]
  generationJobs   GenerationJob[]
  providerUsages   ProviderUsage[]
  idempotencyKeys   IdempotencyKey[]
}

model Provider {
  id               String         @id @default(cuid())
  key              ProviderKey    @unique
  name             String
  slug             String         @unique
  summary          String
  description      String
  defaultModel     String
  status           ProviderStatus @default(ACTIVE)
  isFileUploadBeta Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  chats            Chat[]
  generationJobs   GenerationJob[]
  providerUsages   ProviderUsage[]
}

model Chat {
  id           String      @id @default(cuid())
  userId       String
  providerId   String
  title        String
  status       ChatStatus  @default(ACTIVE)
  lastMessageAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     Provider    @relation(fields: [providerId], references: [id], onDelete: Restrict)
  messages     Message[]
  generationJobs GenerationJob[]
  providerUsages ProviderUsage[]

  @@index([userId, updatedAt])
  @@index([providerId])
}

model Message {
  id              String        @id @default(cuid())
  chatId          String
  userId          String
  role            MessageRole
  status          MessageStatus @default(COMPLETED)
  content         String
  providerMeta    Json?
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  chat            Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments     MessageAttachment[]
  providerUsages  ProviderUsage[]

  @@index([chatId, createdAt])
}

model FileAsset {
  id               String             @id @default(cuid())
  userId           String
  originalName     String
  storageKey       String             @unique
  mimeType         String
  sizeBytes        Int
  checksumSha256   String
  status           FileStatus         @default(READY)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments      MessageAttachment[]

  @@index([userId, createdAt])
}

model MessageAttachment {
  messageId String
  fileId    String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file      FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([messageId, fileId])
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  planCode          String
  status            SubscriptionStatus @default(INACTIVE)
  tokensAllowed     Int                @default(0)
  tokensUsed        Int                @default(0)
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  providerReference String?
  isAutoRenew       Boolean            @default(false)
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model GenerationJob {
  id                String              @id @default(cuid())
  userId            String
  providerId        String
  chatId            String?
  kind              GenerationJobKind
  status            GenerationJobStatus @default(QUEUED)
  prompt            String
  inputPayload      Json?
  resultPayload     Json?
  metadata          Json?
  failureCode       String?
  failureMessage    String?
  providerRequestId String?
  externalJobId     String?
  attemptCount      Int                 @default(0)
  maxAttempts       Int                 @default(3)
  claimOwner        String?
  heartbeatAt       DateTime?
  nextAttemptAt     DateTime?
  queuedAt          DateTime            @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          Provider            @relation(fields: [providerId], references: [id], onDelete: Restrict)
  chat              Chat?               @relation(fields: [chatId], references: [id], onDelete: Cascade)
  providerUsages    ProviderUsage[]

  @@index([userId, createdAt])
  @@index([userId, providerId, kind, createdAt, id])
  @@index([userId, providerId, kind, status, createdAt, id])
  @@index([status, queuedAt])
  @@index([status, nextAttemptAt, queuedAt])
  @@index([status, heartbeatAt])
  @@index([claimOwner, status])
  @@index([providerId, status])
  @@index([chatId])
}

model ProviderUsage {
  id                String                @id @default(cuid())
  userId            String
  providerId        String
  chatId            String?
  messageId         String?
  generationJobId   String?
  operation         ProviderUsageOperation
  model             String
  requestId         String?
  upstreamRequestId String?
  inputTokens       Int?
  outputTokens      Int?
  totalTokens       Int?
  requestUnits      Int?
  latencyMs         Int?
  metadata          Json?
  createdAt         DateTime              @default(now())
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          Provider              @relation(fields: [providerId], references: [id], onDelete: Restrict)
  chat              Chat?                 @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message           Message?              @relation(fields: [messageId], references: [id], onDelete: SetNull)
  generationJob     GenerationJob?        @relation(fields: [generationJobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([providerId, createdAt])
  @@index([chatId])
  @@index([messageId])
  @@index([generationJobId])
  @@index([requestId])
}

model IdempotencyKey {
  id           String                   @id @default(cuid())
  userId       String
  action       IdempotencyAction
  key          String
  requestHash  String
  status       IdempotencyRequestStatus @default(IN_PROGRESS)
  resourceType String?
  resourceId   String?
  response     Json?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, key])
  @@index([userId, createdAt])
  @@index([status, updatedAt])
}
